# Database connection string
# SQLite (default, no external service needed):
DATABASE_URL=sqlite:///tender_platform.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/tender_platform

# Directory for generated documents and uploads
OUTPUT_DIR=output/

# Directory for caching ML models (sentence-transformers, spaCy)
MODEL_CACHE_DIR=output/model_cache/

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit settings (optional)
# STREAMLIT_SERVER_PORT=8501
